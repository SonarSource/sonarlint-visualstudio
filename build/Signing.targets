<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Targets to handle signing artifacts using Sign CLI + Azure Artifact Signing.

       Usage:
       The following items can be set by the caller:
       * @(AssembliesToSign)    : the list of assemblies to sign

       The following environment-backed MSBuild properties must be set when signing:
       * $(SIGNING_ACCOUNT)
       * $(SIGNING_CERTIFICATE_PROFILE)
       * $(SIGNING_ENDPOINT)
  -->
  <Target Name="SignAssemblies">
    <Error Condition=" '$(SIGNING_ACCOUNT)' == '' " Text="SIGNING_ACCOUNT must be set when SignArtifacts=true." />
    <Error Condition=" '$(SIGNING_CERTIFICATE_PROFILE)' == '' " Text="SIGNING_CERTIFICATE_PROFILE must be set when SignArtifacts=true." />
    <Error Condition=" '$(SIGNING_ENDPOINT)' == '' " Text="SIGNING_ENDPOINT must be set when SignArtifacts=true." />
    <Error Condition=" @(AssembliesToSign) == '' " Text="The list of assemblies to sign is empty." />

    <Message Importance="high" Text="Assembly to sign: %(AssembliesToSign.FullPath)" />
    <Exec Command='sign code artifact-signing &quot;%(AssembliesToSign.FullPath)&quot; --artifact-signing-endpoint &quot;$(SIGNING_ENDPOINT)&quot; --artifact-signing-account &quot;$(SIGNING_ACCOUNT)&quot; --artifact-signing-certificate-profile &quot;$(SIGNING_CERTIFICATE_PROFILE)&quot; -v information' />
  </Target>
</Project>
